default_platform(:android)

platform :android do
  desc "Submit a new Beta Build to Firebase App Distribution"
  lane :beta do
    # Run gradle build
    gradle(
      task: "assemble",
      build_type: "Release"
    )

    # Distribute APK to Firebase App Distribution
    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID_ANDROID"],
      testers: ENV["FIREBASE_TESTERS"] || "",
      groups: ENV["FIREBASE_GROUPS"] || "",
      release_notes: "Beta build from GitHub Actions CI/CD"
    )
  end

  desc "Deploy a new version to Firebase App Distribution (Release)"
  lane :release do
    # Run gradle build
    gradle(
      task: "assemble",
      build_type: "Release"
    )

    # Distribute APK to Firebase App Distribution
    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID_ANDROID"],
      testers: ENV["FIREBASE_TESTERS"] || "",
      groups: ENV["FIREBASE_GROUPS"] || "",
      release_notes: "Production release build from GitHub Actions CI/CD"
    )
  end

  desc "Distribute the built APK to Firebase App Distribution"
  lane :distribute do
    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID_ANDROID"],
      apk_path: "../build/app/outputs/flutter-apk/app-release.apk",
      testers: ENV["FIREBASE_TESTERS"] || "",
      groups: ENV["FIREBASE_GROUPS"] || "",
      release_notes: "Local release build"
    )
  end
end
